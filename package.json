{
  "name": "branchos",
  "version": "0.1.0",
  "type": "module",
  "description": "Branch-based AI-assisted development workflow management",
  "main": "dist/index.cjs",
  "bin": {
    "branchos": "./dist/index.cjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
