{
  "name": "branchos",
  "version": "2.2.4",
  "type": "module",
  "description": "Branch-based AI-assisted development workflow management",
  "main": "dist/index.cjs",
  "exports": {
    ".": "./dist/index.cjs"
  },
  "bin": {
    "branchos": "dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thu-Min/branchos.git"
  },
  "homepage": "https://github.com/Thu-Min/branchos",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "branchos",
    "git",
    "workflow",
    "ai",
    "development",
    "cli"
  ],
  "license": "MIT"
}
